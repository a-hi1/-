<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

  <display-name>MBTI职业性格测试系统</display-name>

  <welcome-file-list>
    <welcome-file>index.jsp</welcome-file>
  </welcome-file-list>

  <filter>
    <filter-name>encodingFilter</filter-name>
    <filter-class>com.mbti.web.filter.EncodingFilter</filter-class>
  </filter>
  <filter-mapping>
    <filter-name>encodingFilter</filter-name>
    <url-pattern>/*</url-pattern>
  </filter-mapping>

  <filter>
    <filter-name>authFilter</filter-name>
    <filter-class>com.mbti.web.filter.AuthFilter</filter-class>
  </filter>
  <filter-mapping>
    <filter-name>authFilter</filter-name>
    <url-pattern>/*</url-pattern>
  </filter-mapping>

  <!-- 显式声明部分 Servlet，避免某些 Jetty/部署场景下 @WebServlet 注解未被扫描导致 404 -->

  <servlet>
    <servlet-name>loginServlet</servlet-name>
    <servlet-class>com.mbti.web.LoginServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>loginServlet</servlet-name>
    <url-pattern>/login</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>registerServlet</servlet-name>
    <servlet-class>com.mbti.web.RegisterServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>registerServlet</servlet-name>
    <url-pattern>/register</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>logoutServlet</servlet-name>
    <servlet-class>com.mbti.web.LogoutServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>logoutServlet</servlet-name>
    <url-pattern>/logout</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>homeServlet</servlet-name>
    <servlet-class>com.mbti.web.HomeServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>homeServlet</servlet-name>
    <url-pattern>/app/home</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>changePasswordServlet</servlet-name>
    <servlet-class>com.mbti.web.ChangePasswordServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>changePasswordServlet</servlet-name>
    <url-pattern>/app/password</url-pattern>
  </servlet-mapping>
  <servlet>
    <servlet-name>adminTeamsServlet</servlet-name>
    <servlet-class>com.mbti.web.admin.AdminTeamsServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>adminTeamsServlet</servlet-name>
    <url-pattern>/admin/teams</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>adminDimensionsServlet</servlet-name>
    <servlet-class>com.mbti.web.admin.AdminDimensionsServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>adminDimensionsServlet</servlet-name>
    <url-pattern>/admin/dimensions</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>adminPersonnelServlet</servlet-name>
    <servlet-class>com.mbti.web.admin.AdminPersonnelServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>adminPersonnelServlet</servlet-name>
    <url-pattern>/admin/personnel</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>helpServlet</servlet-name>
    <servlet-class>com.mbti.web.HelpServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>helpServlet</servlet-name>
    <url-pattern>/app/help</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>adminUsersServlet</servlet-name>
    <servlet-class>com.mbti.web.admin.AdminUsersServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>adminUsersServlet</servlet-name>
    <url-pattern>/admin/users</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>adminAssessmentsServlet</servlet-name>
    <servlet-class>com.mbti.web.admin.AdminAssessmentsServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>adminAssessmentsServlet</servlet-name>
    <url-pattern>/admin/assessments</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>adminQuestionsServlet</servlet-name>
    <servlet-class>com.mbti.web.admin.AdminQuestionsServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>adminQuestionsServlet</servlet-name>
    <url-pattern>/admin/questions</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>adminSeedDemoServlet</servlet-name>
    <servlet-class>com.mbti.web.admin.AdminSeedDemoServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>adminSeedDemoServlet</servlet-name>
    <url-pattern>/admin/seed-demo</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>adminSchedulesServlet</servlet-name>
    <servlet-class>com.mbti.web.admin.AdminSchedulesServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>adminSchedulesServlet</servlet-name>
    <url-pattern>/admin/schedules</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>scheduleListServlet</servlet-name>
    <servlet-class>com.mbti.web.test.ScheduleListServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>scheduleListServlet</servlet-name>
    <url-pattern>/test/schedules</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>takeExamServlet</servlet-name>
    <servlet-class>com.mbti.web.test.TakeExamServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>takeExamServlet</servlet-name>
    <url-pattern>/test/take</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>examResultServlet</servlet-name>
    <servlet-class>com.mbti.web.test.ExamResultServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>examResultServlet</servlet-name>
    <url-pattern>/test/result</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>examHistoryServlet</servlet-name>
    <servlet-class>com.mbti.web.test.ExamHistoryServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>examHistoryServlet</servlet-name>
    <url-pattern>/test/history</url-pattern>
  </servlet-mapping>

</web-app>
